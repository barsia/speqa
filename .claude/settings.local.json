{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(printf *)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "Bash(claude plugin:*)",
      "Skill(update-config)",
      "Bash(jar tf:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-spec-edit.sh",
            "statusMessage": "Tracking spec edits"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-kt-edit.sh",
            "statusMessage": "Checking spec-first workflow"
          }
        ]
      }
    ]
  }
}
