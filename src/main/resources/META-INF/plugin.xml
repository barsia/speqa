<idea-plugin>
    <id>io.github.barsia.speqa</id>
    <name>SpeQA - Test Management System</name>
    <vendor url="https://barsia.github.io">Siarhei Baradulia</vendor>
    <description><![CDATA[
        <p>Manual test case management inside your IDE. Test cases are Markdown files stored in your project. Works offline, no external services, no vendor lock-in.</p>
        <ul>
            <li>Split editor: text on the left, interactive preview on the right</li>
            <li>Claude Code skill writes cases from specs, designs, or tickets</li>
            <li>Test runs with verdicts and comments per step</li>
            <li>Git-friendly: diff, blame, revert any change</li>
        </ul>
        <p><a href="https://github.com/barsia/speqa/issues/new?template=bug_report.yml">Report a bug</a> · <a href="https://github.com/barsia/speqa/issues/new?template=feature_request.yml">Request a feature</a> · <a href="https://barsia.github.io/speqa">Docs</a> · <a href="https://github.com/barsia/speqa">GitHub</a> · <a href="https://barsia.github.io">Author</a></p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.compose</depends>
    <depends>org.intellij.plugins.markdown</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>Git4Idea</depends>
    <resource-bundle>messages.SpeqaBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <iconProvider implementation="io.github.barsia.speqa.filetype.SpeqaIconProvider"/>

        <fileEditorProvider implementation="io.github.barsia.speqa.editor.SpeqaEditorProvider"/>
        <fileEditorProvider implementation="io.github.barsia.speqa.run.TestRunEditorProvider"/>

        <annotator language="Markdown" implementationClass="io.github.barsia.speqa.validation.SpeqaAnnotator"/>

        <projectConfigurable parentId="tools"
                             instance="io.github.barsia.speqa.settings.SpeqaSettingsConfigurable"
                             id="io.github.barsia.speqa.settings"
                             key="settings.Speqa.displayName"
                             bundle="messages.SpeqaBundle"/>

        <internalFileTemplate name="SpeQA Test Case.tc.md"/>

        <postStartupActivity implementation="io.github.barsia.speqa.registry.SpeqaIdRegistryStartup"/>

        <newProjectWizard.generator implementation="io.github.barsia.speqa.wizard.SpeqaNewProjectWizard"/>
        <directoryProjectGenerator implementation="io.github.barsia.speqa.wizard.SpeqaProjectGenerator"/>

        <errorHandler implementation="io.github.barsia.speqa.error.SpeqaErrorReportSubmitter"/>

        <psi.referenceContributor language="Markdown"
                                  implementation="io.github.barsia.speqa.editor.SpeqaLinkDestinationReferenceContributor"/>

        <renamePsiElementProcessor
            implementation="io.github.barsia.speqa.refactoring.SpeqaRenamePsiFileProcessor"/>
        <renameInputValidator
            implementation="io.github.barsia.speqa.refactoring.SpeqaRenameInputValidator"/>

        <notificationGroup id="SpeQA" displayType="BALLOON"/>
    </extensions>

    <extensions defaultExtensionNs="JavaScript.JsonSchema">
        <ProviderFactory implementation="io.github.barsia.speqa.filetype.SpeqaFrontmatterSchemaProviderFactory"/>
    </extensions>

    <actions>
        <action id="Speqa.CreateTestCase"
                class="io.github.barsia.speqa.actions.CreateTestCaseAction"
                icon="/icons/testCaseDraft.svg">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
        <action id="Speqa.RunTestCase"
                class="io.github.barsia.speqa.run.RunTestCaseAction">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="Speqa.ToggleScrollSync"
                class="io.github.barsia.speqa.actions.ToggleScrollSyncAction"
                icon="AllIcons.Actions.SynchronizeScrolling">
            <add-to-group group-id="EditorTabsEntryPoint" anchor="last"/>
        </action>
        <action id="Speqa.About"
                class="io.github.barsia.speqa.actions.AboutSpeqaAction"
                icon="/icons/aboutSpeqa.svg">
            <add-to-group group-id="EditorTabsEntryPoint" anchor="last"/>
        </action>
        <group id="Speqa.ToolsMenu" text="SpeQA" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="Speqa.InstallSkill"
                    class="io.github.barsia.speqa.actions.InstallSkillAction"/>
        </group>
    </actions>
</idea-plugin>
