{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "title": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "major", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "deprecated"]
    },
    "environment": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "tags": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    }
  },
  "additionalProperties": true
}
